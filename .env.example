DATABASE_URL=postgresql://clawdbot:clawdbot@localhost:5432/clawdbot

# LLM provider: "gemini" (free tier, default) or "anthropic"
LLM_PROVIDER=gemini
LLM_MODE=enabled
LLM_PROMPT_VERSION=v1
LLM_LABEL_FILTER=["INBOX","UNREAD"]
LLM_FILTER_CANVAS_ALWAYS=true

# Gemini (Google AI Studio — free: 250 req/day, 10 RPM)
# Get key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Anthropic (optional fallback — set LLM_PROVIDER=anthropic to use)
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# Privacy
PRIVACY_STORE_FULL_BODIES=true

# User
USER_TIMEZONE=Asia/Singapore

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_ENABLED=false
