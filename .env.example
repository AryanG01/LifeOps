# =============================================================================
# Clawdbot — Environment Variables
# Copy this file to .env and fill in your values.
# Lines starting with # are comments. Never commit your real .env to git.
# =============================================================================


# -----------------------------------------------------------------------------
# Database
# Local dev: postgresql://clawdbot:clawdbot@localhost:5432/clawdbot
# Railway:   provided automatically via $DATABASE_URL env injection
# Fly.io:    set via `fly secrets set DATABASE_URL=...`
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://clawdbot:clawdbot@localhost:5432/clawdbot


# -----------------------------------------------------------------------------
# LLM — provider: "gemini" (free tier, default) or "anthropic"
# -----------------------------------------------------------------------------

# Get a free Gemini key at: https://aistudio.google.com/app/apikey
# Free tier: 250 req/day, 10 RPM — enough for personal use
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# LLM_PROVIDER controls which key is used for extraction ("gemini" or "anthropic")
LLM_PROVIDER=gemini

# Anthropic (optional — only needed if LLM_PROVIDER=anthropic)
# Get a key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# LLM behaviour
LLM_MODE=enabled                           # "enabled" or "disabled"
LLM_TRIAGE_ENABLED=true                    # pre-filter with cheap model before full extraction
LLM_TRIAGE_MODEL=gemini-2.5-flash-lite     # model used for cheap triage pass
LLM_PROMPT_VERSION=v1
LLM_LABEL_FILTER=["INBOX","UNREAD"]        # only extract from messages with these Gmail labels
LLM_FILTER_CANVAS_ALWAYS=true             # always extract Canvas emails regardless of labels


# -----------------------------------------------------------------------------
# Telegram
# Step 1: Message @BotFather on Telegram -> /newbot -> copy the token below
# Step 2: Start a chat with your bot, then visit:
#           https://api.telegram.org/bot<YOUR_TOKEN>/getUpdates
#         Copy the "id" field from the "chat" object — that is your chat ID
# -----------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_ENABLED=false   # set to true once both values above are filled in

# Minimum task priority (0-100) for an immediate Telegram push notification.
# Tasks with priority >= this value get an inline Accept/Dismiss/Snooze keyboard.
# Default 60 = high-priority tasks only. Set to 0 to push everything.
BOT_NOTIFY_MIN_PRIORITY=60


# -----------------------------------------------------------------------------
# Gmail
# After running `claw connect gmail`, credentials are stored in the OS keychain.
# GMAIL_CREDENTIALS_PATH points to the OAuth client secrets JSON downloaded
# from Google Cloud Console (APIs & Services -> Credentials -> OAuth 2.0 Client ID
# -> Download JSON). Keep this file outside the repo.
# -----------------------------------------------------------------------------
GMAIL_CREDENTIALS_PATH=~/.config/clawdbot/gmail_credentials.json
GMAIL_TOKEN_SERVICE=clawdbot-gmail         # keyring service name for the OAuth token
GMAIL_POLL_INTERVAL_MINUTES=15
GMAIL_MAX_RESULTS=50


# -----------------------------------------------------------------------------
# Outlook / NUS Exchange (optional — skip if you don't use Outlook)
# Register an app at: https://portal.azure.com/ -> Azure Active Directory
#   -> App registrations -> New registration
#   -> Set "Supported account types" to "Accounts in any organizational directory"
#   -> Add a Mobile/Desktop redirect URI: https://login.microsoftonline.com/common/oauth2/nativeclient
# -----------------------------------------------------------------------------
OUTLOOK_CLIENT_ID=
# "organizations" works for NUS Exchange. Use "common" for personal @outlook.com accounts.
OUTLOOK_TENANT=organizations
OUTLOOK_TOKEN_SERVICE=clawdbot-outlook     # keyring service name for the MSAL token


# -----------------------------------------------------------------------------
# Google Calendar (optional — skip if you don't want meeting prep)
# Uses the same Gmail credentials JSON (GMAIL_CREDENTIALS_PATH).
# Run `claw connect gcal` to authorise after Gmail is connected.
# -----------------------------------------------------------------------------
# No additional keys needed — GCal uses the same OAuth credentials as Gmail.


# -----------------------------------------------------------------------------
# API server
# -----------------------------------------------------------------------------
API_HOST=127.0.0.1    # bind only to localhost; change to 0.0.0.0 for Docker/VPS
API_PORT=8000


# -----------------------------------------------------------------------------
# User defaults
# DEFAULT_USER_ID is the UUID of the single user row created by `claw init`.
# USER_DISPLAY_NAME and USER_EMAIL are used by `claw init` to seed the users table.
# Run `claw init` once after setup — it writes DEFAULT_USER_ID to .env automatically.
# -----------------------------------------------------------------------------
DEFAULT_USER_ID=00000000-0000-0000-0000-000000000001
USER_TIMEZONE=Asia/Singapore   # pytz timezone string — used for digest timing
USER_DISPLAY_NAME=Your Name
USER_EMAIL=you@example.com


# -----------------------------------------------------------------------------
# Privacy
# -----------------------------------------------------------------------------
PRIVACY_STORE_FULL_BODIES=true   # set false to store only snippets (saves DB space)
PRIVACY_REDACT_EMAILS=false      # set true to hash all email addresses in logs


# -----------------------------------------------------------------------------
# Web dashboard (optional — leave blank to disable auth in dev)
# -----------------------------------------------------------------------------
DASHBOARD_API_KEY=change_me_in_production
